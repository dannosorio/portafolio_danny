---
interface Props {
  label: string;
  accent?: "cyan" | "pink" | "violet" | "lime" | "default";
}

const { label, accent = "default" } = Astro.props;

const accentClass: Record<NonNullable<Props["accent"]>, string> = {
  default: "",
  cyan: "chip-cyan",
  pink: "chip-pink",
  violet: "chip-violet",
  lime: "chip-lime",
};
---

<span class={`chip ${accentClass[accent]}`}>{label}</span>

<style>
  .chip-cyan {
    color: #b3f0ff;
    border-color: color-mix(in oklab, var(--color-neon-cyan) 45%, transparent);
    background: color-mix(in oklab, var(--color-neon-cyan) 10%, transparent);
  }
  .chip-pink {
    color: #ffc3df;
    border-color: color-mix(in oklab, var(--color-neon-pink) 45%, transparent);
    background: color-mix(in oklab, var(--color-neon-pink) 10%, transparent);
  }
  .chip-violet {
    color: #e0c8ff;
    border-color: color-mix(in oklab, var(--color-neon-violet) 45%, transparent);
    background: color-mix(in oklab, var(--color-neon-violet) 10%, transparent);
  }
  .chip-lime {
    color: #d8ffae;
    border-color: color-mix(in oklab, var(--color-neon-lime) 45%, transparent);
    background: color-mix(in oklab, var(--color-neon-lime) 10%, transparent);
  }
</style>
