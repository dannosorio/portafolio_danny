---
import Section from "../ui/Section.astro";
import NeonButton from "../ui/NeonButton.astro";
import Icon from "../icons/Icon.astro";
import { personal } from "../../data/personal";
---

<Section
  id="contact"
  align="center"
  eyebrow="Contacto"
  title={`¿Tienes una idea? <span class='neon-gradient'>Hablemos</span>.`}
  description="Estoy abierto a colaboraciones, proyectos freelance y oportunidades full-time. La mejor forma de empezar es escribirme directamente."
>
  <div
    class="relative mx-auto max-w-3xl rounded-3xl border border-[var(--color-border-strong)] glass-strong overflow-hidden reveal"
  >
    <div
      class="pointer-events-none absolute -top-24 -left-24 h-64 w-64 rounded-full bg-[radial-gradient(circle,rgba(168,85,247,0.4),transparent_70%)] blur-2xl"
      aria-hidden="true"
    >
    </div>
    <div
      class="pointer-events-none absolute -bottom-24 -right-24 h-64 w-64 rounded-full bg-[radial-gradient(circle,rgba(34,211,238,0.35),transparent_70%)] blur-2xl"
      aria-hidden="true"
    >
    </div>

    <div class="relative p-8 md:p-12 flex flex-col items-center text-center gap-6">
      <span class="chip">
        <span
          class="h-1.5 w-1.5 rounded-full bg-[var(--color-neon-lime)] shadow-[0_0_8px_var(--color-neon-lime)]"
        ></span>
        {personal.availability}
      </span>

      <h3 class="font-[var(--font-display)] text-2xl md:text-4xl font-bold">
        <a
          href={`mailto:${personal.email}`}
          class="neon-text-cyan hover:neon-text-pink transition-colors"
        >
          {personal.email}
        </a>
      </h3>

      <p class="text-[var(--color-text-muted)] max-w-md">
        Cuéntame brevemente sobre tu proyecto, tus objetivos y el tiempo del
        que dispones. Respondo en menos de 24 horas.
      </p>

      <div class="flex flex-wrap items-center justify-center gap-3">
        <NeonButton
          href={`mailto:${personal.email}?subject=Hola%20${encodeURIComponent(personal.shortName)}%20%E2%80%94%20Proyecto`}
          variant="cyan"
        >
          <Icon name="mail" size={16} />
          Enviar correo
        </NeonButton>
        {
          personal.resumeUrl && (
            <NeonButton href={personal.resumeUrl} variant="ghost" external>
              Descargar CV
              <Icon name="arrow-up-right" size={14} />
            </NeonButton>
          )
        }
      </div>

      <div class="flex items-center gap-3 pt-4">
        {
          personal.socials
            .filter((s) => s.icon !== "mail")
            .map((s) => (
              <a
                href={s.href}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={s.label}
                class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-[var(--color-border-strong)] text-[var(--color-text-muted)] hover:text-white hover:border-[var(--color-neon-pink)] hover:shadow-[0_0_20px_rgba(236,72,153,0.35)] transition-all"
              >
                <Icon name={s.icon} size={18} />
              </a>
            ))
        }
      </div>
    </div>
  </div>
</Section>
